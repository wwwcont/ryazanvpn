CONTROL_PLANE_HTTP_ADDR=:8080
HTTP_ADDR=:8080

POSTGRES_DB=ryazanvpn
POSTGRES_USER=ryazanvpn
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_URL=postgres://ryazanvpn:change_me_postgres_password@postgres:5432/ryazanvpn?sslmode=disable

REDIS_ADDR=redis:6379
REDIS_PASSWORD=change_me_redis_password
REDIS_DB=0

LOG_LEVEL=info
SHUTDOWN_TIMEOUT=15s
READINESS_TIMEOUT=2s
LIVENESS_TIMEOUT=2s

NODE_HEALTH_POLL_INTERVAL=15s
NODE_HEALTH_CHECK_TIMEOUT=3s
NODE_HEALTH_MAX_PARALLEL_CHECKS=8
NODE_HEALTH_POLL_JITTER=2s
PEER_CONSISTENCY_INTERVAL=2m

NODE_LINK_CAPACITY_BPS=1000000000
NODE_THROUGHPUT_SAMPLE_STEP=1m
NODE_THROUGHPUT_RETENTION=48h
NODE_RATE_LIMIT_PER_MINUTE=120
ADMIN_RATE_LIMIT_PER_MINUTE=60
OPS_LOG_DIR=./var/opslogs
OPS_LOG_RETENTION=168h

NODE_AGENT_BASE_URL=http://node-agent:8081
NODE_AGENT_TIMEOUT=5s
NODE_AGENT_RETRIES=2
AGENT_HMAC_SECRET=change_me_shared_hmac
NODE_AGENT_HMAC_SECRET=change_me_shared_hmac
AGENT_HMAC_MAX_SKEW=5m
NODE_REGISTRATION_TOKEN=change_me_node_registration_token

ADMIN_API_SECRET=change_me_admin_secret
ADMIN_API_SECRET_HEADER=X-Admin-Secret
CONFIG_MASTER_KEY=change_me_32_bytes_base64_or_strong_key

PUBLIC_BASE_URL=https://api.example.com
PUBLIC_DOMAIN=api.example.com

TELEGRAM_BOT_TOKEN=change_me_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=change_me_telegram_webhook_secret
TELEGRAM_STATE_TTL=300s
TELEGRAM_ADMIN_IDS=123456789
