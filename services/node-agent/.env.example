NODE_AGENT_HTTP_ADDR=:8081
HTTP_ADDR=:8081

LOG_LEVEL=info
SHUTDOWN_TIMEOUT=15s
READINESS_TIMEOUT=2s
LIVENESS_TIMEOUT=2s

CONTROL_PLANE_BASE_URL=http://control-plane:8080
AGENT_HMAC_SECRET=change_me_shared_hmac
NODE_AGENT_HMAC_SECRET=change_me_shared_hmac
AGENT_HMAC_MAX_SKEW=5m

NODE_ID=node-1
NODE_NAME=Node #1
NODE_TOKEN=change_me_node_token
NODE_REGISTRATION_TOKEN=change_me_node_registration_token
NODE_REGION=ru-central
NODE_PUBLIC_IP=203.0.113.10
NODE_CAPACITY=500
NODE_HEARTBEAT_INTERVAL=45s
NODE_PROTOCOLS_SUPPORTED=wireguard,xray

RUNTIME_ADAPTER=amnezia_docker
RUNTIME_WORK_DIR=/var/lib/ryazanvpn/node-agent
RUNTIME_EXEC_TIMEOUT=10s
DOCKER_BINARY_PATH=docker

AMNEZIA_CONTAINER_NAME=amnezia-awg2
AMNEZIA_INTERFACE_NAME=awg0
AMNEZIA_PORT=41475
AMNEZIA_SUBNET=10.8.1.0/24

XRAY_CONTAINER_NAME=ryazanvpn-xray
XRAY_SOURCE_CONFIG_PATH=/opt/xray/config.json
XRAY_PUBLIC_HOST=
XRAY_REALITY_PORT=8443
XRAY_REALITY_SERVER_NAME=www.cloudflare.com
XRAY_REALITY_SHORT_ID=0123456789abcdef
XRAY_REALITY_PRIVATE_KEY=
XRAY_REALITY_PUBLIC_KEY=

VPN_SERVER_PUBLIC_ENDPOINT=
VPN_SERVER_PUBLIC_KEY=
VPN_SUBNET_CIDR=10.8.1.0/24
VPN_CLIENT_ALLOWED_IPS=0.0.0.0/0,::/0
VPN_AWG_MTU=1376
