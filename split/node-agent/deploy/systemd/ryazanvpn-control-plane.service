[Unit]
Description=RyazanVPN Control Plane
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ryazanvpn
Group=ryazanvpn
WorkingDirectory=/opt/ryazanvpn
EnvironmentFile=/etc/ryazanvpn/control-plane.env
ExecStart=/opt/ryazanvpn/bin/control-plane
Restart=always
RestartSec=2
LimitNOFILE=65535
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
