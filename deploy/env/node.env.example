# Required for runtime wiring: AMNEZIA_CONTAINER_NAME, AMNEZIA_INTERFACE_NAME, XRAY_CONTAINER_NAME, DOCKER_BINARY_PATH
NODE_AGENT_HTTP_ADDR=:8081
HTTP_ADDR=:8081

LOG_LEVEL=info
SHUTDOWN_TIMEOUT=15s
READINESS_TIMEOUT=2s
LIVENESS_TIMEOUT=2s

AGENT_HMAC_SECRET=rzn_agent_hmac_local_2026
AGENT_HMAC_MAX_SKEW=5m

CONTROL_PLANE_BASE_URL=https://api.example.com
NODE_AGENT_BASE_URL=http://node-agent:8081
NODE_AGENT_TIMEOUT=5s

NODE_ID=11111111-1111-1111-1111-111111111111
NODE_TOKEN=rzn_node_token_local_2026
NODE_NAME=node-1
NODE_REGION=ru-mow
NODE_PUBLIC_IP=203.0.113.10
NODE_CAPACITY=200
NODE_PROTOCOLS_SUPPORTED=wireguard,xray
NODE_HEARTBEAT_INTERVAL=45s

RUNTIME_ADAPTER=amnezia_docker
RUNTIME_WORK_DIR=/var/lib/ryazanvpn/node-agent
RUNTIME_EXEC_TIMEOUT=10s
DOCKER_BINARY_PATH=docker
AMNEZIA_CONTAINER_NAME=amnezia-awg2
AMNEZIA_INTERFACE_NAME=awg0
XRAY_CONTAINER_NAME=ryazanvpn-xray
XRAY_REALITY_PRIVATE_KEY=xray_reality_private_key_local_2026
