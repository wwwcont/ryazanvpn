# ==============================
# ryazanvpn single-server env
# ==============================
# Заполните значения и разнесите в соответствующие env-файлы сервисов
# (control-plane, node-agent, postgres, redis) либо используйте как reference.

# ---------- Common ----------
LOG_LEVEL=
SHUTDOWN_TIMEOUT=
READINESS_TIMEOUT=

# ---------- PostgreSQL ----------
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_URL=

# ---------- Redis ----------
REDIS_ADDR=
REDIS_PASSWORD=
REDIS_DB=

# ---------- Control-plane ----------
CONTROL_PLANE_HTTP_ADDR=
ADMIN_API_SECRET=
ADMIN_API_SECRET_HEADER=
CONFIG_MASTER_KEY=
PUBLIC_BASE_URL=

# Node agent access from control-plane
NODE_AGENT_BASE_URL=
NODE_AGENT_HMAC_SECRET=
NODE_AGENT_TIMEOUT=
NODE_AGENT_RETRIES=

# Workers
NODE_HEALTH_POLL_INTERVAL=
NODE_HEALTH_CHECK_TIMEOUT=

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_STATE_TTL=
TELEGRAM_ADMIN_IDS=

# ---------- Node-agent ----------
NODE_AGENT_HTTP_ADDR=
AGENT_HMAC_SECRET=
AGENT_HMAC_MAX_SKEW=

# Runtime selection
RUNTIME_ADAPTER=
RUNTIME_WORK_DIR=
AWG_BINARY_PATH=
WG_BINARY_PATH=
IP_BINARY_PATH=
RUNTIME_EXEC_TIMEOUT=

# Runtime peer stats scaffold
RUNTIME_STATS_BINARY_PATH=
RUNTIME_STATS_ARGS=

# ---------- Optional service ports ----------
CONTROL_PLANE_PUBLIC_PORT=
NODE_AGENT_PUBLIC_PORT=
POSTGRES_PUBLIC_PORT=
REDIS_PUBLIC_PORT=
