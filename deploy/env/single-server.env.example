# HTTP listen addresses (service-scoped, preferred)
CONTROL_PLANE_HTTP_ADDR=:8080
NODE_AGENT_HTTP_ADDR=:8081
# Backward compatibility fallback (used only when scoped variables are not set)
HTTP_ADDR=:8080

POSTGRES_DB=ryazanvpn
POSTGRES_USER=ryazanvpn
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_URL=postgres://ryazanvpn:CHANGE_ME@postgres:5432/ryazanvpn?sslmode=disable

REDIS_ADDR=redis:6379
REDIS_PASSWORD=CHANGE_ME
REDIS_DB=0

LOG_LEVEL=info
SHUTDOWN_TIMEOUT=15s
READINESS_TIMEOUT=2s
LIVENESS_TIMEOUT=2s

NODE_AGENT_BASE_URL=http://node-agent:8081
NODE_AGENT_HMAC_SECRET=CHANGE_ME
NODE_AGENT_TIMEOUT=5s
NODE_AGENT_RETRIES=2
AGENT_HMAC_SECRET=CHANGE_ME
AGENT_HMAC_MAX_SKEW=5m

ADMIN_API_SECRET=CHANGE_ME
ADMIN_API_SECRET_HEADER=X-Admin-Secret
CONFIG_MASTER_KEY=BASE64_AES_KEY

PUBLIC_BASE_URL=https://api.example.com
PUBLIC_DOMAIN=api.example.com

TELEGRAM_BOT_TOKEN=REPLACE_ME
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME
TELEGRAM_STATE_TTL=300s
TELEGRAM_ADMIN_IDS=123456789

VPN_SERVER_PUBLIC_ENDPOINT=203.0.113.1:51820
VPN_SERVER_PUBLIC_KEY=REPLACE_ME
VPN_SUBNET_CIDR=10.8.1.0/24
VPN_CLIENT_ALLOWED_IPS=0.0.0.0/0,::/0

RUNTIME_ADAPTER=amnezia_docker
AMNEZIA_CONTAINER_NAME=amnezia-awg2
AMNEZIA_INTERFACE_NAME=awg0
DOCKER_BINARY_PATH=/usr/bin/docker
RUNTIME_EXEC_TIMEOUT=10s
