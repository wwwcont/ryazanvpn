# === Service listen addresses ===
CONTROL_PLANE_HTTP_ADDR=:8080
NODE_AGENT_HTTP_ADDR=:8081

# === Datastores ===
POSTGRES_DB=ryazanvpn
POSTGRES_USER=ryazanvpn
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_URL=postgres://ryazanvpn:change_me_postgres_password@postgres:5432/ryazanvpn?sslmode=disable

REDIS_ADDR=redis:6379
REDIS_PASSWORD=change_me_redis_password
REDIS_DB=0

# === Core runtime ===
LOG_LEVEL=info
NODE_AGENT_BASE_URL=http://node-agent:8081
CONTROL_PLANE_BASE_URL=http://control-plane:8080
AGENT_HMAC_SECRET=change_me_shared_agent_hmac
NODE_AGENT_HMAC_SECRET=change_me_shared_agent_hmac
ADMIN_API_SECRET=change_me_admin_api_secret
CONFIG_MASTER_KEY=change_me_32_bytes_base64_or_strong_key

NODE_ID=single-node-1
NODE_TOKEN=change_me_node_token
NODE_LINK_CAPACITY_BPS=1000000000
NODE_THROUGHPUT_SAMPLE_STEP=1m
NODE_THROUGHPUT_RETENTION=48h
OPS_LOG_DIR=./var/opslogs
OPS_LOG_RETENTION=168h

PUBLIC_BASE_URL=https://api.example.com
TELEGRAM_BOT_TOKEN=change_me_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=change_me_telegram_webhook_secret
TELEGRAM_ADMIN_IDS=123456789

# === External runtime integration ===
RUNTIME_ADAPTER=amnezia_docker
DOCKER_BINARY_PATH=docker
AMNEZIA_CONTAINER_NAME=amnezia-awg2
AMNEZIA_INTERFACE_NAME=awg0
XRAY_CONTAINER_NAME=ryazanvpn-xray


# === Runtime source paths (used by sync script) ===
# Amnezia values are read from live runtime via docker exec/awg show.
# Xray values are read from runtime config file:
XRAY_SOURCE_CONFIG_PATH=/opt/xray/config.json
XRAY_REALITY_PRIVATE_KEY=
XRAY_REALITY_PUBLIC_KEY=

# Host/IP used to build VPN_SERVER_PUBLIC_ENDPOINT=<host>:<amnezia ListenPort>
VPN_PUBLIC_HOST=203.0.113.10

# === Values auto-filled by scripts/sync-runtime-from-configs.sh ===
VPN_SERVER_PUBLIC_ENDPOINT=
VPN_SERVER_PUBLIC_KEY=
VPN_SUBNET_CIDR=
XRAY_PUBLIC_HOST=
XRAY_REALITY_PORT=
XRAY_REALITY_SERVER_NAME=
XRAY_REALITY_SHORT_ID=

# === Static client defaults ===
VPN_CLIENT_ALLOWED_IPS=0.0.0.0/0,::/0
VPN_AWG_JC=4
VPN_AWG_JMIN=10
VPN_AWG_JMAX=50
VPN_AWG_S1=50
VPN_AWG_S2=74
VPN_AWG_S3=45
VPN_AWG_S4=16
VPN_AWG_H1=1391505721-1463481553
VPN_AWG_H2=1725378175-1834354614
VPN_AWG_H3=2076643873-2118219660
VPN_AWG_H4=2141781406-2147031473
VPN_AWG_I1=<r 2><b 0x858000010001000000000669636c6f756403636f6d0000010001c00c000100010000105a00044d583737>
VPN_AWG_I2=
VPN_AWG_I3=
VPN_AWG_I4=
VPN_AWG_I5=
VPN_AWG_MTU=1376
